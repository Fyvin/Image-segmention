#图像矫正
# mark点相对位置固定
# mark点越远越好
# mark点不共享(3点以上)
def Affine_ZC(img, src, dst):
    h,w = img.shape[:2]
    M = cv2.getAffineTransform(src, dst)
    Affine_img = cv2.warpAffine(
        img, M, (w, h),
        flags=cv2.INTER_LINEAR,
        borderMode=cv2.BORDER_REPLICATE
    )
    return Affine_img
